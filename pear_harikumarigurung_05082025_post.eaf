    <TIER DEFAULT_LOCALE="en" LINGUISTIC_TYPE_REF="po"
        PARENT_REF="ref@w4r" PARTICIPANT="A" TIER_ID="po@w4r">
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a4" ANNOTATION_REF="a2">
                <ANNOTATION_VALUE>toraa mi kri mumae wa tsa mi kri </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a19" ANNOTATION_REF="a17">
                <ANNOTATION_VALUE>sĩdũtũr tsali phalphula avokadodo taba mumae ke </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a49" ANNOTATION_REF="a47">
                <ANNOTATION_VALUE>tsa tõrimae ani tsa tõirõno tsai ma tõirõ pheri tsali tsutiri tongye tõbiõ taba mala mumae ke </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a64" ANNOTATION_REF="a62">
                <ANNOTATION_VALUE>tsa tibo lairõ tõmmae ani </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a79" ANNOTATION_REF="a77">
                <ANNOTATION_VALUE>pheri ma yum tõr tsar tõmo tõr kri ma sar tiamae </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a94" ANNOTATION_REF="a92">
                <ANNOTATION_VALUE>the sar tiuni the thea kharirba rumala </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a109" ANNOTATION_REF="a107">
                <ANNOTATION_VALUE>kya plisi the tsai pustĩro tsar thĩsyõ ke</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a124" ANNOTATION_REF="a122">
                <ANNOTATION_VALUE>hai thĩmo tsakya the raa awodzawae khaimo tsa ra ngyemo </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a139" ANNOTATION_REF="a137">
                <ANNOTATION_VALUE>ani mi kri the tsa ra tsãĩboi yasyõ the wa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a154" ANNOTATION_REF="a152">
                <ANNOTATION_VALUE>tsa ra tsãĩboi yamo tsa mi-yi the sĩdũtũrba tsa avokado tõsimo </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a169" ANNOTATION_REF="a167">
                <ANNOTATION_VALUE>arko kolo kri khammae tsa kolo kri the pheri saikalar</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a184" ANNOTATION_REF="a182">
                <ANNOTATION_VALUE>saikalar the tsa mi tu mur tõrimo tõri tsai avokado tsa </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a199" ANNOTATION_REF="a197">
                <ANNOTATION_VALUE>thea saikala agadi tora thĩmmae</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a214" ANNOTATION_REF="a212">
                <ANNOTATION_VALUE>tsar thĩrõno the bommae boi yamo tõri </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a229" ANNOTATION_REF="a227">
                <ANNOTATION_VALUE>kitsai kya kri rimae saikala tsali khammae wa </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a244" ANNOTATION_REF="a242">
                <ANNOTATION_VALUE>tsa saikala tsali khamo tõri tsa ri- tsa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a259" ANNOTATION_REF="a257">
                <ANNOTATION_VALUE>thea kyaar angini ? tsa rimaeri ngimo tõri yuma wutheri mumae </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a274" ANNOTATION_REF="a272">
                <ANNOTATION_VALUE>tsa yumari kuturairõno tsaungi de tsar </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a289" ANNOTATION_REF="a287">
                <ANNOTATION_VALUE>kolo laphliamae wa laphliauni the</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a304" ANNOTATION_REF="a302">
                <ANNOTATION_VALUE>tsar tongye oo tsali oo tsutiri tsa </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a319" ANNOTATION_REF="a317">
                <ANNOTATION_VALUE>tsali klõgudi gem klõba mala tsa</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a334" ANNOTATION_REF="a332">
                <ANNOTATION_VALUE>wuthiri bol tingo paniũdo taba to biura tsa </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a353" ANNOTATION_REF="a347">
                <ANNOTATION_VALUE>tsa tsa tsali klõrimae </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a354" ANNOTATION_REF="a348">
                <ANNOTATION_VALUE>tsamae tsa kyaar klõrimae</ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a355" ANNOTATION_REF="a349">
                <ANNOTATION_VALUE>sõũlõ mi sõũlõ tsar klõrimae </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
        <ANNOTATION>
            <REF_ANNOTATION ANNOTATION_ID="a394" ANNOTATION_REF="a392">
                <ANNOTATION_VALUE>hai tsa klõriuni the tora tsa </ANNOTATION_VALUE>
            </REF_ANNOTATION>
        </ANNOTATION>
